# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.venv-mobileclip/
__pycache__/
*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.claude

/onepiece

# Bulk local datasets — keep untracked, except minimal Pokémon stubs for CI/Docker.
/data/*
!/data/pokemon/
/data/pokemon/*
!/data/pokemon/sets.json
!/data/pokemon/series.json
!/data/pokemon/pokemon.json
!/data/pokemon/cards/
/data/pokemon/cards/*
!/data/pokemon/cards/.gitkeep