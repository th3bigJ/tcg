{
  "name": "tcg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:missing-cards": "node --import tsx/esm scripts/seedMissingCardsFromScrydex.ts",
    "seed:missing-sets": "node --import tsx/esm scripts/seedMissingScrydexSets.ts",
    "seed:missing-set-images": "node --import tsx/esm scripts/uploadSeededImagesToR2.ts",
    "backfill:price-history": "node --import tsx/esm scripts/backfillPriceHistoryFromScrydex.ts",
    "backfill:sealed-price-history": "node --import tsx/esm scripts/backfillSealedPriceHistoryFromPokedata.ts",
    "scrape:pricing": "node --import tsx/esm scripts/scrapePricing.ts",
    "scrape:pokedata-products": "node --import tsx/esm scripts/scrapePokedataProducts.ts",
    "scrape:pokedata-products:catalog": "node --import tsx/esm scripts/scrapePokedataProducts.ts --mode=products --tcg=Pokemon --language=ENGLISH",
    "scrape:pokedata-products:prices": "node --import tsx/esm scripts/scrapePokedataProducts.ts --mode=prices --tcg=Pokemon --language=ENGLISH",
    "portfolio:snapshot": "node --import tsx/esm scripts/snapshotPortfolio.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tcgdex/sdk": "^2.7.1",
    "next": "^16.2.0",
    "onnxruntime-web": "^1.24.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
