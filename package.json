{
  "name": "tcg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "start": "node --import tsx/esm nightly-scrape/server.ts",
    "lint": "eslint",
    "scrape:pricing": "node --import tsx/esm nightly-scrape/scrapePricing.ts",
    "scrape:pokedata-products": "node --import tsx/esm nightly-scrape/scrapePokedataProducts.ts",
    "scrape:pokedata-products:catalog": "node --import tsx/esm nightly-scrape/scrapePokedataProducts.ts --mode=products --tcg=Pokemon --language=ENGLISH",
    "scrape:pokedata-products:prices": "node --import tsx/esm nightly-scrape/scrapePokedataProducts.ts --mode=prices --tcg=Pokemon --language=ENGLISH",
    "scrape:onepiece-pricing": "node --import tsx/esm nightly-scrape/scrapeOnePiecePricing.ts",
    "scrape:market-trends": "node --import tsx/esm nightly-scrape/runTrends.ts"
  },
  "dependencies": {
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
