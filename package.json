{
  "name": "tcg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:missing-cards": "node --import tsx/esm scripts/seedMissingCardsFromScrydex.ts",
    "seed:missing-sets": "node --import tsx/esm scripts/seedMissingScrydexSets.ts",
    "seed:missing-set-images": "node --import tsx/esm scripts/uploadSeededImagesToR2.ts",
    "backfill:price-history": "node --import tsx/esm scripts/backfillPriceHistoryFromScrydex.ts",
    "backfill:swsh-tg-external-ids": "node --import tsx/esm scripts/backfillSwshTrainerGalleryExternalIds.ts",
    "dedupe:price-history-sv-prefixes": "node --import tsx/esm scripts/dedupeSinglesPriceHistorySvPrefixes.ts",
    "backfill:sealed-price-history": "node --import tsx/esm scripts/backfillSealedPriceHistoryFromPokedata.ts",
    "scrape:pricing": "node --import tsx/esm scripts/scrapePricing.ts",
    "scrape:scrydex-card-meta": "node --import tsx/esm scripts/scrapeScrydexCardMeta.ts",
    "scrape:pokedata-products": "node --import tsx/esm scripts/scrapePokedataProducts.ts",
    "scrape:pokedata-products:catalog": "node --import tsx/esm scripts/scrapePokedataProducts.ts --mode=products --tcg=Pokemon --language=ENGLISH",
    "scrape:pokedata-products:prices": "node --import tsx/esm scripts/scrapePokedataProducts.ts --mode=prices --tcg=Pokemon --language=ENGLISH",
    "portfolio:snapshot": "node --import tsx/esm scripts/snapshotPortfolio.ts",
    "portfolio:snapshot:fix-dates": "node --import tsx/esm scripts/backfillPortfolioSnapshotTodayToYesterday.ts",
    "r2:migrate-pokemon-bucket": "node --import tsx/esm scripts/r2MigratePokemonBucketIntoTcg.ts",
    "r2:upload-static-data": "node --import tsx/esm scripts/uploadStaticCardDataToR2.ts",
    "r2:replace-mirrored-data": "node --import tsx/esm scripts/replaceMirroredDataOnR2.ts",
    "r2:download-static-data": "node --import tsx/esm scripts/downloadStaticCardDataFromR2.ts",
    "r2:rename-pricing-to-card-pricing": "node --import tsx/esm scripts/r2RenamePricingToCardPricing.ts",
    "r2:nest-singles-pricing-under-pricing": "node --import tsx/esm scripts/r2NestSinglesPricingUnderPricingFolder.ts",
    "r2:move-sealed-pokedata-json": "node --import tsx/esm scripts/r2MoveSealedPokedataJsonToDataAndPricing.ts",
    "r2:move-pokemon-graded-under-images": "node --import tsx/esm scripts/r2MovePokemonAndGradedUnderImages.ts",
    "r2:move-sets-under-images": "node --import tsx/esm scripts/r2MoveSetsUnderImages.ts",
    "r2:migrate-pricing-gbp-to-usd": "node --import tsx/esm scripts/migrateR2PricingGbpToUsd.ts",
    "migrate:singles-pricing-keys": "node --import tsx/esm scripts/migrateSinglesPricingKeysToCanonical.ts",
    "scrape:onepiece-sets": "node --import tsx/esm scripts/scrapeOnePieceSets.ts",
    "scrape:onepiece-cards": "node --import tsx/esm scripts/scrapeOnePieceCards.ts",
    "scrape:onepiece-pricing": "node --import tsx/esm scripts/scrapeOnePiecePricing.ts",
    "backfill:onepiece-price-history": "node --import tsx/esm scripts/backfillOnePiecePriceHistory.ts",
    "r2:upload-onepiece": "node --import tsx/esm scripts/uploadOnePieceFolderToR2.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tcgdex/sdk": "^2.7.1",
    "next": "^16.2.0",
    "node-cron": "^4.2.1",
    "onnxruntime-web": "^1.24.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
